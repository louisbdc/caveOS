// Modèle de configuration des secrets de build (committé, sans valeur réelle).
//
// Mise en place :
//   1. cp Configuration/Secrets.example.xcconfig Configuration/Secrets.xcconfig
//   2. génère une clé :  openssl rand -hex 32
//   3. colle-la ci-dessous dans Secrets.xcconfig (qui est gitignoré)
//   4. pose la MÊME valeur sur le VPS :  ./scripts/set_env.sh CAVEOS_SCAN_KEY
//
// La clé est injectée dans Info.plist (CaveOSScanKey) et envoyée par l'app dans
// l'en-tête X-CaveOS-Key. Le serveur la compare à CAVEOS_SCAN_KEY (refus 401 si
// absente/incorrecte). NB : un secret embarqué dans le binaire reste extractible
// — il bloque l'abus opportuniste, pas un attaquant déterminé.
CAVEOS_SCAN_KEY = changeme
